# ===========================================
# Pixemingle Environment Variables
# ===========================================

# --- Supabase ---
# Public Supabase project URL (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Public Supabase anon key (safe for client-side, RLS-protected)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Supabase service role key (server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- OpenClaw Gateway ---
# Shared secret for authenticating requests between Vercel and the Gateway
# Must match GATEWAY_SECRET in gateway/.env
OPENCLAW_GATEWAY_SECRET=your-shared-secret-here

# --- Stripe ---
# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_...
# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe publishable key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- App ---
# Public-facing app URL (used for OAuth callbacks, Stripe redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dev Auth (development only) ---
# Passwords for dev login bypass accounts (used by /api/dev/login)
DEV_USER_PASSWORD_1=dev-password-change-me
DEV_USER_PASSWORD_2=dev-password-change-me
