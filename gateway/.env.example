# Anthropic API key for Claude Haiku LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Supabase connection (for agent_routing, agent_memories, theater_turns)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shared secret for Pixemingle API <-> Gateway authentication
# NOTE: This is the same value as OPENCLAW_GATEWAY_SECRET in the main project's Vercel env.
GATEWAY_SECRET=your-shared-secret-here

# Pixemingle Next.js app URL (for POSTing theater turn decisions)
APP_URL=https://pixemingle.com

# Express server port (default 3001)
PORT=3001

# Agent workspace data directory (default /data/agents)
DATA_DIR=/data/agents
